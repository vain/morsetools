#!/usr/bin/env python3

from random import choice
from string import ascii_letters, digits
from subprocess import DEVNULL, PIPE, Popen
from time import sleep

phonetic_alphabet = {
    'a': 'Alpha',
    'b': 'Bravo',
    'c': 'Charlie',
    'd': 'Delta',
    'e': 'Echo',
    'f': 'Foxtrot',
    'g': 'Golf',
    'h': 'Hotel',
    'i': 'India',
    'j': 'Juliet',
    'k': 'Kilo',
    'l': 'Lima',
    'm': 'Mike',
    'n': 'November',
    'o': 'Oscar',
    'p': 'Papa',
    'q': 'Quebec',
    'r': 'Romeo',
    's': 'Sierra',
    't': 'Tango',
    'u': 'Uniform',
    'v': 'Victor',
    'w': 'Whiskey',
    'x': 'X-ray',
    'y': 'Yankee',
    'z': 'Zulu',
}

def morse(c):
    # Like morsetrainer_linewise, this extra space is a hackaround for
    # power saving modes of some soundcards.
    cmd = 'echo " {}" | t2m -c 0.5 | aplay -qr 44100 -f S16_LE'.format(c)
    player = Popen(cmd, shell=True)
    player.communicate()

def say(c):
    espeak = Popen(['espeak', '-s', '120'], stdin=PIPE, stderr=DEVNULL)

    espeak.stdin.write(
        '{}, {}.'.format(
            c.upper(), phonetic_alphabet.get(c.lower(), '')
        ).encode()
    )
    espeak.communicate()

if __name__ == '__main__':
    while True:
        c = choice(ascii_letters + digits)
        for i in range(2):
            morse(c)
            sleep(1)
            say(c)
            sleep(1)
        sleep(2)
