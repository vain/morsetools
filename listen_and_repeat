#!/usr/bin/env python3

from random import choice
from string import ascii_letters, digits
from subprocess import DEVNULL, PIPE, Popen
from time import sleep

def morse(c):
    t2m = Popen(['t2m', '-c', '0.9'], stdin=PIPE, stdout=PIPE)
    aplay = Popen(['aplay', '-r', '44100', '-f', 'S16_LE'],
                  stdin=t2m.stdout, stderr=DEVNULL)

    # Like morsetrainer_linewise, this extra space is a hackaround for
    # power saving modes of some soundcards.
    t2m.stdin.write((' ' + c).encode())

    t2m.stdin.flush()
    t2m.stdin.close()
    aplay.wait()

def say(c):
    espeak = Popen(['espeak'], stdin=PIPE, stderr=DEVNULL)

    espeak.stdin.write(c.encode())
    espeak.communicate()

if __name__ == '__main__':
    while True:
        c = choice(ascii_letters + digits)
        for i in range(2):
            morse(c)
            sleep(1)
            say(c)
            sleep(1)
        sleep(2)
